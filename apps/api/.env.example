# ==== Social Posting Automation — API env ====
# Copy to .env (same folder). NEVER commit .env.

APP_ENV=dev
API_BASE_URL=http://localhost:8000
WEB_ORIGIN=http://localhost:3000
RUN_WORKER=true

# --- security (REQUIRED) ---
# Generate:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENC_KEY_B64=
TOKEN_ENC_KEY_VERSION=1
# Generate:  python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# --- database / storage ---
DATABASE_URL=sqlite:///./data/app.db
STORAGE_DIR=./storage
MAX_UPLOAD_MB=200

# --- LinkedIn (from your app at developer.linkedin.com > Auth tab) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/oauth/linkedin/callback
LINKEDIN_API_VERSION=202506
ENABLE_LINKEDIN_REAL=true

# --- platforms still in demo mode (real adapters: next milestone) ---
ENABLE_FACEBOOK_REAL=false
ENABLE_TWITTER_REAL=false
ENABLE_YOUTUBE_REAL=false
